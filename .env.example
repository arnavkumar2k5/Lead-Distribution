# ─── Neon connection string ───────────────────────────────────────────────────
#
# In your Neon dashboard → Connection Details → select "Prisma" from dropdown.
# It gives you two URLs:
#
# 1. POOLED (use this as DATABASE_URL for the app at runtime):
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"
#
# 2. DIRECT (only needed for migrations/db push — add as a second var):
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"
#
# Base URL for internal webhook calls
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
